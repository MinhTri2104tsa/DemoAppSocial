# Server environment example
# Copy this file to .env and fill in real values. Do NOT commit the real .env to git.

# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=socialapp

# Server
PORT=4000

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# CORS - comma separated origins (optional)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
